{
  "name": "frontend-interview-prep",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "lsof -ti :3737 -ti :3000 | xargs kill -9 2>/dev/null || true",
    "dev": "concurrently -n dashboard,notes -c blue,magenta \"npm run dashboard\" \"npm run notes\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "dashboard": "node dashboard/server.js",
    "notes": "cd notes && npm start",
    "notes:build": "cd notes && npm run build",
    "notes:install": "cd notes && npm install"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/react": "^8.4.0",
    "@storybook/react-vite": "^8.4.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/ui": "^4.1.2",
    "concurrently": "^9.2.1",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
